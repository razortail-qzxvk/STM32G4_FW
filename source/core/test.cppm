// ============================================================================
// 1. 全局模块片段 (Global Module Fragment)
// ============================================================================
// 必须在文件的最开头。
// 作用：用于 #include 传统的 C/C++ 头文件。
// 特性：这里包含的宏定义 (Macros) 和声明 **不会** 泄漏给导入我们这个模块的用户。
// 这彻底解决了 C++ 几十年来的宏污染问题！
module;

#include <cstdint> // 比如嵌入式常用的定长整数头文件

// ============================================================================
// 2. 模块级声明 (Module Declaration)
// ============================================================================
// 声明这是 `test` 模块的 "主模块接口文件" (Primary Module Interface Unit)。
// export 表明这个文件对外部提供接口。
export module test;

// 若有需要，可以在这里 import 其他模块。
// import std; // C++23 的标准库模块，目前很多嵌入式工具链还没带，仅作演示。

// ============================================================================
// 3. 导出单个函数/变量
// ============================================================================
export int add(int a, int b) {
    return a + b;
}

// 导出一个模板（不需要像以前那样把声明和实现全挤在头文件，但实际上编译器内部还是会处理代码可见性）
export template <typename T>
T clamp(T val, T min, T max) {
    if (val < min) return min;
    if (val > max) return max;
    return val;
}

// ============================================================================
// 4. 不导出的内部实现 (Module-internal linkage)
// ============================================================================
// 这里没有写 export，所以外界完全看不到、也无法调用 `internal_multiply`。
// 就如同在传统 .cpp 里加了 `static` 或放入匿名 namespace 一样。
int internal_multiply(int a, int b) {
    return a * b;
}

// ============================================================================
// 5. 导出整个命名空间 (Export Namespace)
// ============================================================================
// 方便地把一堆东西一次性暴露出去。
export namespace test::math {
    // 命名空间内可以直接调用模块内的非导出函数
    int multiply(int a, int b) {
        return internal_multiply(a, b);
    }

    // 导出类 (类的成员函数如果在这里实现，默认会自动内联)
    class Calculator {
    public:
        Calculator(int base) : base_(base) {}
        int calculate(int x) const { return base_ + x; }
    private:
        int base_; // 外面访问不到，符合正常的封装逻辑
    };
}

// ============================================================================
// 6. 导出块 (Export Block)
// ============================================================================
// 如果不想写 namespace，也不想每行都写 export，可以用花括号包起来。
export {
    constexpr uint32_t VERSION_MAJOR = 1;
    constexpr uint32_t VERSION_MINOR = 0;

    enum class Status : uint8_t {
        OK = 0,
        ERROR = 1,
        BUSY = 2
    };
}

// ============================================================================
// 7. 关于模块分区 (Module Partitions) 的说明
// ============================================================================
/* 
如果你的模块超级庞大，比如整个硬件的 HAL 层：
你可以将其拆分成多个文件（分区），对外依然作为一个单独的模块 `test` 暴露：

  文件1 `test-gpio.cppm` (接口分区): 
    export module test:gpio;
    export void gpio_init();

  文件2 `test-adc.cppm` (接口分区):
    export module test:adc;
    export void adc_init();

  然后在主模块 `test.cppm` (本文件) 中合并它们并重新导出：
    export import :gpio;
    export import :adc;
*/

// ============================================================================
// 8. 私有模块片段 (Private Module Fragment) 
// ============================================================================
// [重要限制]：只有当这是该模块的唯一文件（即没有分离出别的 .cpp 实现文件，
// 也没有用到上面的分区）时，才能使用模块私有片段。
module :private;

// 分界线！----------------------------------------------------------------------
// 作用：屏障。在这条线以下写的任何实现代码如果被修改，
// 所有 `import test;` 的文件 **均不需要重新编译**！(打破了物理依赖隔离)
// 你可以把函数的声明放在上面（不要带实体），把函数的实现体放在这里。
// 比如我们上面本可以写 `export int add(int a, int b);`，然后在这里写完整实现。
// 这样在仅修改实现逻辑的时候，能节省大量的增量编译时间。
